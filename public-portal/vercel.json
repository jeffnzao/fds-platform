# Configuration Vercel pour le portail public
# Ce fichier indique à Vercel de déployer uniquement le dossier public-portal

# Variables d'environnement pour Vercel
NEXT_PUBLIC_API_URL=https://api-fds-platform.vercel.app/api/v1

# Build settings
buildCommand: npm run build
devCommand: npm run dev
installCommand: npm install
outputDirectory: .next

# Redirects pour SPA
rewrites:
  - source: '/api/:path*'
    destination: 'https://api-fds-platform.vercel.app/api/:path*'