# =============================================
# FDS Platform — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# =============================================

# Environnement
NODE_ENV=development

# PostgreSQL
POSTGRES_PASSWORD=fds_secret_2024

# Redis
REDIS_PASSWORD=redis_secret

# JWT (CHANGER EN PRODUCTION — générer avec: openssl rand -base64 64)
JWT_SECRET=change_this_jwt_secret_in_production_minimum_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MinIO (stockage fichiers)
MINIO_ROOT_USER=fds_minio
MINIO_ROOT_PASSWORD=minio_secret_2024

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-app-password

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
